# LLM - Cloud (OpenRouter)：前端下拉选项，逗号分隔 id；LABELS 为显示名，顺序与 MODELS 一致
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MODELS=openrouter/auto,qwen/qwen-2.5-7b-instruct,google/gemini-2.5-flash
OPENROUTER_LABELS=Auto,Qwen,Gemini

# LLM - Local (Ollama)：目前仅一个选项
# 启动后端时自动启动 Ollama（若未运行）；设为 0 禁用
AUTO_START_OLLAMA=1
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODELS=qwen2.5:7b
OLLAMA_LABELS=qwen2.5:7b