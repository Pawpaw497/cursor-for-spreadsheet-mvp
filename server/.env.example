# LLM - Cloud (OpenRouter)：前端下拉选项，逗号分隔；LABELS 为显示名（auto, 中国, 国外 等）
OPENROUTER_API_KEY=YOUR_KEY
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MODELS=openrouter/auto,openrouter/anthropic/claude-3.5-sonnet,openrouter/google/gemini-2.0-flash-001
OPENROUTER_LABELS=auto,中国,国外

# LLM - Local (Ollama)：目前仅一个选项
# 启动后端时自动启动 Ollama（若未运行）；设为 0 禁用
AUTO_START_OLLAMA=1
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODELS=qwen2.5:7b
OLLAMA_LABELS=qwen2.5:7b