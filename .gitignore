# =============================================================================
# Project-specific (this repository) — 保留的自定义项
# =============================================================================
# dotenv 与敏感配置（含密钥，勿提交）
.env
.env.*
!.env.example
example.env
py.env
server/.env

# 仅作本地使用的路径
/.history
/env

# 按团队约定不纳入版本库
scripts/
docs/

